---
import LazyVideo from './LazyVideo.astro';
import placeholders from '../data/placeholders.json';
const G = "rgb(206, 206, 202)";
const ph = (src: string) => `background-image: url('${placeholders[src as keyof typeof placeholders]}')`;
---
<section class="section">

  <!-- ═════════ ECRU ═════════ -->
  <p class="label">ecru 2023</p>

  <div class="grid g-4pfs4w">
    <div class="cell s5 el-lv9nzq" style={ph('/assets/videos/e-v1.mp4')}><LazyVideo src="/assets/videos/e-v1.mp4" /></div>
  </div>

  <div class="grid g-ehjzkl">
    <div class="spacer s1 e-zr4qak"></div>
    <div class="text-cell s5 t-1gd2b4t">
      <div class="tw">
        <div class="real" style="transform:none">
          <p>ecru is a streetwear brand for which i designed a website from the first concept to launch. there are thick and tight layouts, broken image rows, all-lowercase, edge cut-off logos and dotted icons as core visual constants.</p>
          <p>for now, there is no catalogue, cart and checkout, just a space with lookbooks to get inspired by the latest campaigns and a store locator to find the nearest store.</p>
          <p>take a look at<br>
            <a href="https://www.ecrubrand.com/en" target="_blank" rel="noopener" class="lnk">ecrubrand.com/en</a>
          </p>
        </div>
        <div class="shadow" style="transform:rotateX(180deg)" aria-hidden="true">
          <p style={`color:${G}`}>ecru is a streetwear brand...</p>
          <p style={`color:${G}`}>for now, there is no catalogue...</p>
          <p style={`color:${G}`}>take a look at<br>ecrubrand.com/en</p>
        </div>
      </div>
    </div>
  </div>

  <div class="grid g-cinhwh">
    <div class="spacer h77 s4 hide-768"></div>
    <div class="cell ar-111 s8 el-15qx98s" style={ph('/assets/images/e-1.jpg')}><img src="/assets/images/e-1.jpg" alt="" loading="lazy" /></div>
  </div>

  <div class="grid g-1hangmz">
    <div class="spacer h77 s2 hide-768"></div>
    <div class="e-1tegzwc-spc"></div>
    <div class="cell ar-111 s8 el-1tegzwc" style={ph('/assets/images/e-2.jpg')}><img src="/assets/images/e-2.jpg" alt="" loading="lazy" /></div>
  </div>

  <div class="grid">
    <div class="cell ar-129 sfull" style={ph('/assets/images/e-3.jpg')}><img src="/assets/images/e-3.jpg" alt="" loading="lazy" /></div>
  </div>

  <div class="grid g-19p3p7a">
    <div class="e-1dsnla0"></div>
    <div class="cell ar-111 s4 e-17hidpd" style={ph('/assets/images/e-4.jpg')}><img src="/assets/images/e-4.jpg" alt="" loading="lazy" /></div>
    <div class="cell ar-111 s4 e-1sswkl7" style={ph('/assets/images/e-5.jpg')}><img src="/assets/images/e-5.jpg" alt="" loading="lazy" /></div>
  </div>

  <div class="grid g-a7fo5a">
    <div class="spacer s6 e-10olj9u"></div>
    <div class="cell ar-122 s6 el-d75n2r" style={ph('/assets/images/e-6.jpg')}><img src="/assets/images/e-6.jpg" alt="" loading="lazy" /></div>
  </div>

  <div class="archive-header">
    <p class="label">archive 2015–2018</p>
  </div>

  <div class="grid g-1c4jotq">
    <div class="cell ar-158 s7 el-1dhkv88" style={ph('/assets/images/a-phones.jpg')}><img src="/assets/images/a-phones.jpg" alt="" loading="lazy" /></div>
  </div>

  <div class="grid g-spj3wd">
    <div class="s5 e-1eid7c9"></div>
    <div class="cell ar-158 s5 el-1fmm573" style={ph('/assets/videos/a-v1.mp4')}><LazyVideo src="/assets/videos/a-v1.mp4" /></div>
  </div>

  <div class="grid">
    <div class="cell ar-170 s8" style={ph('/assets/videos/a-v2.mp4')}><LazyVideo src="/assets/videos/a-v2.mp4" /></div>
  </div>

  <div class="grid g-e8bocw">
    <div class="e-1f41tc1 s4"></div>
    <div class="cell ar-76 s3 el-1ds3zij" style={ph('/assets/images/a-card.jpg')}><img src="/assets/images/a-card.jpg" alt="" loading="lazy" /></div>
    <div class="cell ar-76 s5 el-6bibu8" style={ph('/assets/images/a-high.jpg')}><img src="/assets/images/a-high.jpg" alt="" loading="lazy" /></div>
  </div>

  <div class="grid g-1uk384">
    <div class="e-cvr4du s3"></div>
    <div class="cell ar-158 s6 el-15kwrdd" style={ph('/assets/images/a-catalog.jpg')}><img src="/assets/images/a-catalog.jpg" alt="" loading="lazy" /></div>
  </div>

</section>

<style>
  .section {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--gap);
    padding-top: 80px;
  }
  .label {
    font-family: var(--font); font-size: var(--fs);
    line-height: var(--lh); letter-spacing: var(--ls);
    color: var(--text); font-weight: 400; margin: 0;
  }
  .dim { opacity: 0.5; }
  .archive-header { padding-top: 80px; }

.text-cell { overflow: visible; min-width: 0; }
  .tw { position: relative; overflow: hidden; }
  .real {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; gap: 16px;
    font-family: var(--font); font-size: var(--fs);
    line-height: var(--lh); letter-spacing: var(--ls);
    color: var(--text); font-weight: 400; word-break: break-word;
  }
  .real p { margin: 0; }
  .shadow {
    position: absolute; top: 0; left: 0; width: 100%;
    z-index: 0; opacity: 0.6;
    display: flex; flex-direction: column; gap: 16px;
    font-family: var(--font); font-size: var(--fs);
    line-height: var(--lh); font-weight: 400;
    pointer-events: none; user-select: none;
  }
  .shadow p { margin: 0; }
  .lnk {
    display: inline-block; padding-left: 1.5em;
    color: var(--muted);
    transition: color 0.2s cubic-bezier(.44,0,.56,1);
  }
  .lnk:hover { color: var(--text); }

  /* g-4pfs4w */
  @media (max-width: 1023px) {
    .el-lv9nzq { grid-column: auto / span 7; }
  }
  @media (max-width: 767px) {
    .el-lv9nzq { grid-column: 1 / -1; }
  }

  /* g-1uk384 */
  @media (max-width: 1023px) {
    .e-cvr4du  { grid-column: auto / span 4; }
    .el-15kwrdd { grid-column: auto / span 8; }
  }
  @media (max-width: 767px) {
    .e-cvr4du   { display: none; }
    .el-15kwrdd { grid-column: 1 / -1; }
  }

  /* g-e8bocw */
  @media (max-width: 1023px) {
    .e-1f41tc1  { grid-column: auto / span 3; }
    .el-1ds3zij { grid-column: auto / span 4; }
    .el-6bibu8  { grid-column: auto / span 5; }
  }
  @media (max-width: 767px) {
    .e-1f41tc1  { grid-column: auto / span 2; }
    .el-1ds3zij { grid-column: auto / span 4; }
    .el-6bibu8  { grid-column: auto / span 4; }
  }

  /* g-spj3wd */
  @media (max-width: 1023px) {
    .e-1eid7c9  { grid-column: auto / span 6; }
    .el-1fmm573 { grid-column: auto / span 6; }
  }
  @media (max-width: 767px) {
    .e-1eid7c9  { grid-column: auto / span 1; }
    .el-1fmm573 { grid-column: auto / span 5; }
  }

  /* g-a7fo5a */
  @media (max-width: 1023px) {
    .e-10olj9u { grid-column: auto / span 4; }
    .el-d75n2r { grid-column: auto / span 8; }
  }
  @media (max-width: 767px) {
    .e-10olj9u { display: none; }
    .el-d75n2r { grid-column: 1 / -1; }
  }

  /* g-19p3p7a */
  .e-1dsnla0 { display: none; }
  @media (max-width: 1023px) {
    .e-17hidpd { grid-column: auto / span 8; }
    .e-1sswkl7 { grid-column: auto / span 6; }
  }
  @media (max-width: 767px) {
    .e-1dsnla0 { display: block; grid-column: auto / span 2; }
    .e-17hidpd { grid-column: auto / span 4; }
    .e-1sswkl7 { grid-column: auto / span 4; }
  }

  /* el-1tegzwc: <768 s5 + spacer s1 */
  .e-1tegzwc-spc { display: none; }
  @media (max-width: 767px) {
    .e-1tegzwc-spc { display: block; grid-column: auto / span 1; }
    .el-1tegzwc    { grid-column: auto / span 5; }
  }

  /* g-ehjzkl: spacer скрыт на мобилке */
  @media (max-width: 767px) {
    .e-zr4qak  { display: none; }
  }
  /* g-ehjzkl: текст */
  @media (max-width: 1023px) {
    .t-1gd2b4t { grid-column: auto / span 6; }
  }
  @media (max-width: 767px) {
    .t-1gd2b4t { grid-column: 1 / -1; }
  }

  /* g-1c4jotq: <1024 s10 */
  @media (max-width: 1023px) {
    .el-1dhkv88 { grid-column: auto / span 10; }
  }

  /* ── 1024–1439px ── */
  @media (min-width: 1024px) and (max-width: 1439px) {
  }

  /* ── ≤768px ── */
  @media (max-width: 768px) {
    .hide-768    { display: none; }
    .el-lv9nzq  { grid-column: 1 / -1; }
    .t-1gd2b4t  { grid-column: 1 / -1; }
    .el-15qx98s { grid-column: 1 / -1; }

    .el-d75n2r  { grid-column: 1 / -1; }
    .el-1dhkv88 { grid-column: 1 / -1; }

  }

  /* ── ≤600px ── */
  @media (max-width: 600px) {
    .archive-header { padding-top: 40px; }
    .section { padding-top: 40px; }
  }
</style>
